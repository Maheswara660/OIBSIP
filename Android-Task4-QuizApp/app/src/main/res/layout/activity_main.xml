<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:padding="20dp"
    tools:context=".MainActivity">

    <!-- Active Quiz View Container -->
    <ScrollView
        android:id="@+id/layoutQuizView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Header Title -->
            <TextView
                android:id="@+id/tvAppTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/quiz_title"
                android:textColor="@color/text_white"
                android:textSize="26sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/quiz_subtitle"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvAppTitle" />

            <!-- Progress Text -->
            <TextView
                android:id="@+id/tvProgressText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:textColor="@color/text_white"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="Question 1 of 6"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvSubtitle" />

            <!-- Progress Bar -->
            <ProgressBar
                android:id="@+id/progressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="10dp"
                android:layout_marginTop="8dp"
                android:progressDrawable="@drawable/bg_progress"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvProgressText"
                tools:progress="33" />

            <!-- Question Card View -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardQuestion"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/progressBar">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Question Prompt Text -->
                    <TextView
                        android:id="@+id/tvQuestionText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:lineSpacingExtra="4dp"
                        android:textColor="@color/text_white"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        tools:text="What is the capital city of France?" />

                    <!-- Options Radio Group -->
                    <RadioGroup
                        android:id="@+id/radioGroupOptions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:orientation="vertical">

                        <RadioButton
                            android:id="@+id/rbOption1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:background="@drawable/bg_option_selector"
                            android:buttonTint="@color/purple_accent"
                            android:paddingStart="16dp"
                            android:paddingTop="14dp"
                            android:paddingEnd="16dp"
                            android:paddingBottom="14dp"
                            android:textColor="@color/radio_text_color"
                            android:textSize="15sp"
                            tools:text="Paris" />

                        <RadioButton
                            android:id="@+id/rbOption2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:background="@drawable/bg_option_selector"
                            android:buttonTint="@color/purple_accent"
                            android:paddingStart="16dp"
                            android:paddingTop="14dp"
                            android:paddingEnd="16dp"
                            android:paddingBottom="14dp"
                            android:textColor="@color/radio_text_color"
                            android:textSize="15sp"
                            tools:text="London" />

                        <RadioButton
                            android:id="@+id/rbOption3"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:background="@drawable/bg_option_selector"
                            android:buttonTint="@color/purple_accent"
                            android:paddingStart="16dp"
                            android:paddingTop="14dp"
                            android:paddingEnd="16dp"
                            android:paddingBottom="14dp"
                            android:textColor="@color/radio_text_color"
                            android:textSize="15sp"
                            tools:text="Berlin" />

                        <RadioButton
                            android:id="@+id/rbOption4"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_option_selector"
                            android:buttonTint="@color/purple_accent"
                            android:paddingStart="16dp"
                            android:paddingTop="14dp"
                            android:paddingEnd="16dp"
                            android:paddingBottom="14dp"
                            android:textColor="@color/radio_text_color"
                            android:textSize="15sp"
                            tools:text="Madrid" />

                    </RadioGroup>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Next / Submit Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNext"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp"
                android:backgroundTint="@color/purple_accent"
                android:text="@string/next_question"
                android:textColor="@color/text_white"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="14dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardQuestion"
                app:layout_constraintVertical_bias="1.0" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </ScrollView>

    <!-- Quiz Result Summary View Container (Hidden initially) -->
    <ScrollView
        android:id="@+id/layoutResultView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="visible">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tvResultHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="@string/quiz_completed"
                android:textColor="@color/text_white"
                android:textSize="28sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardResult"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:strokeWidth="0dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvResultHeader">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="32dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/your_score"
                        android:textColor="@color/text_secondary"
                        android:textSize="16sp" />

                    <!-- Score display e.g. 5 / 6 -->
                    <TextView
                        android:id="@+id/tvScoreSummary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:textColor="@color/text_white"
                        android:textSize="44sp"
                        android:textStyle="bold"
                        tools:text="5 / 6" />

                    <!-- Percentage display e.g. 83% -->
                    <TextView
                        android:id="@+id/tvPercentage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/purple_accent_light"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        tools:text="83.3%" />

                    <!-- Dynamic feedback message badge -->
                    <TextView
                        android:id="@+id/tvFeedbackMessage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:background="@drawable/bg_option_selected"
                        android:paddingStart="20dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="20dp"
                        android:paddingBottom="10dp"
                        android:textColor="@color/text_white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        tools:text="Outstanding Performance!" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Restart Quiz Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRestart"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:backgroundTint="@color/purple_accent"
                android:text="@string/restart_quiz"
                android:textColor="@color/text_white"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="14dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardResult" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
