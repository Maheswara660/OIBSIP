# ==============================================================================
# OIBSIP Android Portfolio Master .gitignore
# ==============================================================================

# ------------------------------------------------------------------------------
# Built Application Packages & Binaries
# ------------------------------------------------------------------------------
*.apk
*.aar
*.ap_
*.aab
*.dex
*.class

# ------------------------------------------------------------------------------
# Generated Build & Intermediate Directories
# ------------------------------------------------------------------------------
build/
**/build/
app/build/
bin/
gen/
out/

# ------------------------------------------------------------------------------
# Gradle Files & Caching
# ------------------------------------------------------------------------------
.gradle/
**/.gradle/
gradle-app.setting
!.gradle/wrapper/gradle-wrapper.jar
!**/gradle/wrapper/gradle-wrapper.jar
!**/gradle/wrapper/gradle-wrapper.properties

# ------------------------------------------------------------------------------
# Kotlin Caches & Metadata
# ------------------------------------------------------------------------------
.kotlin/
**/.kotlin/
*.kotlin_module
*.kotlin_builtins

# ------------------------------------------------------------------------------
# Local Configuration & SDK Paths
# ------------------------------------------------------------------------------
local.properties
**/local.properties
*.log
**/*.log

# ------------------------------------------------------------------------------
# Android Studio / IntelliJ IDEA Configuration
# ------------------------------------------------------------------------------
.idea/
**/.idea/
*.iml
**/*.iml
.navigation/
captures/
**/captures/
*.hprof
.externalNativeBuild/
**/.externalNativeBuild/
.cxx/
**/.cxx/

# Preserve essential VCS settings if desired
!.idea/codeStyles
!.idea/copyright

# ------------------------------------------------------------------------------
# VS Code & Editor Configurations
# ------------------------------------------------------------------------------
.vscode/
**/.vscode/
*.swp
*.bak
*~

# ------------------------------------------------------------------------------
# Android Signing Keys & Secret Credentials
# ------------------------------------------------------------------------------
*.jks
*.keystore
*.pepk
*.p12
*.pfx
*.pem
*.crt
*.key
google-services.json
GoogleService-Info.plist

# ------------------------------------------------------------------------------
# Operating System Files (macOS / Windows / Linux)
# ------------------------------------------------------------------------------
.DS_Store
**/.DS_Store
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini
